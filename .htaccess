# ============================================================
# NEXTIWEB — .htaccess
# Serveur Apache / Hostinger
# ============================================================

# ---- Activer le module Rewrite ----
Options -Indexes
RewriteEngine On

# ---- 1. Forcer HTTPS ----
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ---- 2. Forcer www → sans www (canonical domain) ----
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# ---- 3. Redirections blog (aliases catégories FR/EN) ----
RewriteRule ^en/blog/creation-site/?$ /en/blog/website-design/ [R=301,L]
RewriteRule ^en/blog/marketing-digital/?$ /en/blog/digital-marketing/ [R=301,L]
RewriteRule ^en/blog/ia-automatisation/?$ /en/blog/ai-automation/ [R=301,L]
RewriteRule ^blog/website-design/?$ /blog/creation-site/ [R=301,L]
RewriteRule ^blog/digital-marketing/?$ /blog/marketing-digital/ [R=301,L]
RewriteRule ^blog/ai-automation/?$ /blog/ia-automatisation/ [R=301,L]

# ---- 3b. Anciennes URLs WordPress → pages actuelles (301) ----
RewriteRule ^agence-de-creation-de-site-e-commerce-performantes/?$ /creation-site.html [R=301,L]
RewriteRule ^agence-de-creation-de-sites-internet-adaptes/?$ /creation-site.html [R=301,L]
RewriteRule ^creation-de-site-internet-et-conception-de-site-web/?$ /creation-site.html [R=301,L]
RewriteRule ^contactez-nous/?$ /contact.html [R=301,L]

# ---- 3c. Consolidation Core Web Vitals (301) ----
RewriteRule ^blog/seo/performance-core-web-vitals\.html$ /blog/seo/vitesse-technique-core-web-vitals.html [R=301,L]
RewriteRule ^en/blog/seo/core-web-vitals-guide\.html$ /en/blog/seo/website-speed-technical-sme.html [R=301,L]
RewriteRule ^en/blog/seo/performance-core-web-vitals\.html$ /en/blog/seo/website-speed-technical-sme.html [R=301,L]

# ---- 3d. URLs mortes (410 Gone) ----
RewriteRule ^feed/?$ - [R=410,L]

# ---- 4. Page 404 personnalisée ----
ErrorDocument 404 /404.html

# ---- 4. Compression GZIP ----
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# ---- 5. Cache navigateur (performance) ----
<IfModule mod_expires.c>
  ExpiresActive On

  # Images
  ExpiresByType image/webp          "access plus 6 months"
  ExpiresByType image/png           "access plus 6 months"
  ExpiresByType image/jpg           "access plus 6 months"
  ExpiresByType image/jpeg          "access plus 6 months"
  ExpiresByType image/svg+xml       "access plus 6 months"
  ExpiresByType image/x-icon        "access plus 1 year"

  # CSS & JS
  ExpiresByType text/css            "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/javascript     "access plus 1 month"

  # Fonts
  ExpiresByType font/woff2          "access plus 1 year"
  ExpiresByType font/woff           "access plus 1 year"

  # HTML — cache court : les changements de contenu se voient vite (CDN + navigateur)
  ExpiresByType text/html           "access plus 10 minutes"
</IfModule>

# ---- 6. En-têtes sécurité ----
<IfModule mod_headers.c>
  # Empêche le clickjacking
  Header always set X-Frame-Options "SAMEORIGIN"
  # Empêche le MIME sniffing
  Header always set X-Content-Type-Options "nosniff"
  # Protection XSS navigateurs anciens
  Header always set X-XSS-Protection "1; mode=block"
  # Référent — ne pas envoyer l'URL complète vers des tiers
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  # HSTS — force le navigateur à toujours utiliser HTTPS (1 an, sous-domaines inclus)
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  # Permissions-Policy — désactive caméra / micro / géolocalisation par défaut
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  # Supprime la signature serveur
  Header unset Server
  Header unset X-Powered-By
  # HTML : revalidation pour que les mises à jour de contenu soient prises vite
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=600, must-revalidate"
  </FilesMatch>
</IfModule>

# ---- 7. Bloquer l'accès aux fichiers sensibles ----
<FilesMatch "(^\.htaccess|\.htpasswd|build-blog\.js|README\.md|mail-config\.php|smtp-mailer\.php)">
  Order Allow,Deny
  Deny from all
</FilesMatch>

# ---- 8. Type MIME correct pour WebP ----
<IfModule mod_mime.c>
  AddType image/webp .webp
  AddType font/woff2 .woff2
</IfModule>
