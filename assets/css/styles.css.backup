/* =========================
   STYLES GLOBAUX NEXTIWEB
   ========================= */

/* RESET SIMPLE */
*,
*::before,
*::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

/* VARIABLES & THEME */
:root {
  --color-bg: #0f0f0f;
  --color-bg-alt: #000000;
  --color-bg-alt-2: #0a0a0a;
  --color-surface: #111111;
  --color-surface-alt: #101010;
  --color-surface-soft: #0c0c0c;
  --color-primary: #00e676;
  --color-primary-dark: #009e4f;
  --color-primary-deep: #006837;
  --color-text: #ffffff;
  --color-text-muted: #c8c8c8;
  --color-text-light: #9a9a9a;
  --color-border: #1a1a1a;
  --color-border-strong: #262626;
  --color-border-soft: #333333;
  --color-header-bg: rgba(0, 0, 0, 0.9);
  --color-topbar-bg: #101010;
  --color-menu-bg: rgba(0, 0, 0, 0.95);
  --color-footer-bg: #000000;
  --color-card-hover: #141414;
  --color-shadow-soft: rgba(0, 0, 0, 0.35);
  --color-shadow-strong: rgba(0, 0, 0, 0.45);
  --theme-toggle-bg: rgba(255, 255, 255, 0.04);

  --font-family-base: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
    Roboto, "Helvetica Neue", Arial, sans-serif;

  --container-width: 1120px;
  --section-padding-y: 6rem;
  --border-radius: 0.5rem;
  --transition-smooth: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

/* BASE TYPO & LAYOUT */
html {
  font-size: 16px;
}

body {
  background-color: var(--color-bg);
  color: var(--color-text);
  font-family: var(--font-family-base);
  line-height: 1.6;
  transition: background-color 0.25s ease, color 0.25s ease;
}

body.theme-light {
  --color-bg: #f5efe6;
  --color-bg-alt: #fffdf9;
  --color-bg-alt-2: #eee4d6;
  --color-surface: #fffdf9;
  --color-surface-alt: #f8efe3;
  --color-surface-soft: #fff8ef;
  --color-text: #171717;
  --color-text-muted: #4f4f4f;
  --color-text-light: #6e6e6e;
  --color-border: #ded1c0;
  --color-border-strong: #cdbda9;
  --color-border-soft: #baa892;
  --color-header-bg: rgba(255, 250, 244, 0.94);
  --color-topbar-bg: #efe1cf;
  --color-menu-bg: rgba(255, 250, 244, 0.98);
  --color-footer-bg: #ead9c5;
  --color-card-hover: #fbf3e8;
  --color-shadow-soft: rgba(82, 55, 24, 0.12);
  --color-shadow-strong: rgba(82, 55, 24, 0.18);
  --theme-toggle-bg: #ffffff;
}

/* Correctifs de contraste WCAG en mode light */
body.theme-light a {
  color: #006837;
}

body.theme-light a:hover {
  color: #004d27;
}

body.theme-light .section--cta {
  background: linear-gradient(135deg, #003d1f, #006837);
}

body.theme-light .top-bar__highlight {
  color: #006837;
}

body.theme-light .top-bar__phone {
  color: #006837;
}

body.theme-light .top-bar__phone:hover {
  color: #004d27;
}

a {
  color: var(--color-primary);
  text-decoration: none;
  transition: color 0.25s ease;
}

a:hover {
  color: var(--color-primary-dark);
}

/* Containers & sections */

.container {
  width: 100%;
  max-width: var(--container-width);
  margin: 0 auto;
  padding: 0 1.5rem;
}

.section {
  padding: var(--section-padding-y) 0;
  animation: fadeInUp 0.7s ease 0.1s both;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.section--dark {
  background-color: var(--color-bg-alt);
}

.section--cta {
  background: linear-gradient(135deg, var(--color-primary-deep), var(--color-primary));
  text-align: center;
}

.section--cta .section__title,
.section--cta .section__text,
.section--cta .section__subtitle {
  color: #ffffff;
}

.section--alt-bg {
  background-color: var(--color-bg-alt-2);
}

.section__header {
  margin-bottom: 2rem;
}

.section__header--center {
  text-align: center;
  max-width: 640px;
  margin-left: auto;
  margin-right: auto;
}

.section__title {
  font-size: 2.5rem;
  margin-bottom: 0.75rem;
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: 1.15;
}

.section__text {
  color: var(--color-text-muted);
  font-size: 1.05rem;
  line-height: 1.7;
}

.section__subtitle {
  color: var(--color-text-muted);
  font-size: 1.1rem;
  max-width: 560px;
  line-height: 1.7;
}

.section__actions {
  margin-top: 1.5rem;
}

/* =========================
   TOP BAR (ENGAGEMENT)
   ========================= */

.top-bar {
  background-color: var(--color-topbar-bg);
  border-bottom: 1px solid var(--color-border);
  font-size: 0.85rem;
  padding: 0.5rem 0;
  position: sticky;
  top: 0;
  z-index: 25;
}

.top-bar__inner {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  min-height: 1.25rem;
  padding-right: 10rem;
}

.top-bar__message {
  color: var(--color-text-muted);
  margin: 0;
  font-size: 0.85rem;
  text-align: center;
  transition: opacity 0.3s ease;
}

.top-bar__highlight {
  color: var(--color-primary);
  font-weight: 600;
}

.top-bar__phone {
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  color: var(--color-primary);
  font-weight: 700;
  font-size: 0.9rem;
  letter-spacing: 0.01em;
  white-space: nowrap;
}

.top-bar__phone:hover {
  color: var(--color-primary-dark);
}

/* =========================
   HEADER & NAV GLOBAL
   ========================= */

.site-header {
  position: sticky;
  top: 0;
  z-index: 20;
  background-color: var(--color-header-bg);
  backdrop-filter: blur(10px);
}

.header__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1rem 0;
}

.logo img {
  height: 70px;
}

.main-nav {
  display: flex;
  align-items: center;
  gap: 1.5rem;
}

.nav__item {
  position: relative;
}

.nav__item > .nav__link {
  cursor: pointer;
}

.nav__item > .nav__link::after {
  content: "";
  display: inline-block;
  width: 0.4rem;
  height: 0.4rem;
  border: solid var(--color-text);
  border-width: 0 2px 2px 0;
  margin-left: 0.4rem;
  transform: rotate(45deg);
  transition: transform 0.3s ease;
}

.nav__item.is-open > .nav__link::after {
  transform: rotate(-135deg);
}

.nav__submenu {
  position: absolute;
  top: 100%;
  left: 0;
  background-color: var(--color-menu-bg);
  border: 1px solid var(--color-border);
  border-radius: 0.5rem;
  min-width: 200px;
  margin-top: 0.5rem;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transition: opacity 0.3s ease, visibility 0.3s ease;
  z-index: 100;
  box-shadow: 0 10px 30px var(--color-shadow-strong);
}

.nav__item:hover .nav__submenu {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
}

.nav__item.is-open .nav__submenu {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
}

.nav__submenu-link {
  display: block;
  padding: 0.75rem 1rem;
  color: var(--color-text);
  font-size: 0.9rem;
  transition: color 0.2s ease, background-color 0.2s ease;
  border-left: 3px solid transparent;
}

.nav__submenu-link:hover {
  color: var(--color-primary);
  background-color: rgba(0, 230, 118, 0.05);
  border-left-color: var(--color-primary);
}

.nav__submenu-link:first-child {
  border-top-left-radius: 0.5rem;
  border-top-right-radius: 0.5rem;
}

.nav__submenu-link:last-child {
  border-bottom-left-radius: 0.5rem;
  border-bottom-right-radius: 0.5rem;
}

.nav__link {
  font-size: 0.95rem;
  color: var(--color-text);
  transition: color 0.3s ease;
}

.nav__link:hover {
  color: var(--color-primary);
}

.nav__link--active {
  color: var(--color-primary);
}

.nav__link--cta {
  padding: 0.5rem 1rem;
  border-radius: 999px;
  background-color: var(--color-primary);
  color: #000000;
  font-weight: 600;
  transition: background-color 0.3s ease;
}

.nav__link--cta:hover {
  background-color: var(--color-primary-dark);
  color: #ffffff;
}

.theme-toggle {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.55rem;
  min-width: 9.5rem;
  border: 1px solid var(--color-border-soft);
  background: var(--theme-toggle-bg);
  color: var(--color-text);
  border-radius: 999px;
  padding: 0.5rem 0.85rem;
  cursor: pointer;
  font: inherit;
  font-size: 0.9rem;
  font-weight: 600;
  line-height: 1;
  box-shadow: 0 8px 18px var(--color-shadow-soft);
  transition: var(--transition-smooth);
}

.theme-toggle:hover {
  border-color: var(--color-primary);
  transform: translateY(-1px);
}

.theme-toggle:focus-visible {
  outline: none;
  box-shadow: 0 0 0 4px rgba(0, 230, 118, 0.14);
}

.theme-toggle__icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 1.5rem;
  height: 1.5rem;
  border-radius: 999px;
  background-color: rgba(0, 230, 118, 0.12);
  color: var(--color-primary);
  font-size: 0.95rem;
  flex-shrink: 0;
}

.theme-toggle__text {
  white-space: nowrap;
}

.language-switcher {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
  border: 1px solid var(--color-border-soft);
  border-radius: 999px;
  padding: 0.2rem;
  background: var(--theme-toggle-bg);
  box-shadow: 0 8px 18px var(--color-shadow-soft);
}

.language-switcher__btn {
  border: 0;
  background: transparent;
  color: var(--color-text-muted);
  border-radius: 999px;
  padding: 0.3rem 0.6rem;
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.03em;
  cursor: pointer;
  transition: var(--transition-smooth);
}

.language-switcher__btn:hover {
  color: var(--color-text);
}

.language-switcher__btn.is-active {
  color: #000000;
  background-color: var(--color-primary);
}

.language-switcher__btn:focus-visible {
  outline: none;
  box-shadow: 0 0 0 3px rgba(0, 230, 118, 0.15);
}

/* =========================
   HERO IMMERSIF EN BACKGROUND
   ========================= */

.hero-bg {
  position: relative;
  min-height: 65vh;
  display: flex;
  /* pour pouvoir coller le contenu en bas */
  align-items: stretch;
  overflow: hidden;
  background-image:
    linear-gradient(to right, rgba(3, 15, 26, 0.42) 0%, rgba(3, 15, 26, 0.14) 58%, rgba(3, 15, 26, 0) 100%),
    url("../img/hero/hero-nextiweb.webp");
  background-size: cover;
  background-position: center right;
  color: var(--color-text);
}

.hero-bg::before {
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
  background:
    radial-gradient(circle at 12% 18%, rgba(0, 230, 118, 0.26), rgba(0, 230, 118, 0) 44%),
    radial-gradient(circle at 84% 24%, rgba(92, 216, 255, 0.18), rgba(92, 216, 255, 0) 40%);
  z-index: 0;
}

body.theme-light .hero-bg,
body.theme-light .hero-bg__kicker,
body.theme-light .hero-bg__headline,
body.theme-light .hero-bg__subtitle,
body.theme-light .hero-bg__microcopy {
  color: #f7f7f7;
}

.hero-bg__overlay {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at top left, rgba(0, 230, 118, 0.26), transparent 52%),
    linear-gradient(to bottom, rgba(7, 25, 42, 0.04), rgba(7, 25, 42, 0.34));
  pointer-events: none;
}

.hero-bg__inner {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  padding: 4.5rem 0 2.5rem;
}

.hero-bg__content {
  max-width: 620px;
  /* pousse le bloc en bas du hero */
  margin-top: auto;
  display: flex;
  flex-direction: column;
  min-height: 48vh;
  justify-content: flex-end;
}

.hero-bg__kicker {
  display: inline-block;
  margin: 0 0 0.7rem;
  font-size: 0.86rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: rgba(188, 244, 222, 0.95);
  animation: slideUp 0.8s ease 0.1s both;
}

.hero-bg__title {
  font-size: 1.2rem;
  line-height: 1.35;
  margin-bottom: 0.55rem;
  font-weight: 600;
  letter-spacing: 0.01em;
  text-transform: none;
  text-shadow: 0 8px 28px rgba(0, 0, 0, 0.3);
  animation: slideUp 0.8s ease 0.2s both;
}

.hero-bg__headline {
  font-size: clamp(2rem, 4.8vw, 3.1rem);
  line-height: 1.08;
  margin: 0 0 1rem;
  font-weight: 700;
  letter-spacing: -0.02em;
  color: #ffffff;
  text-shadow: 0 8px 28px rgba(0, 0, 0, 0.35);
  animation: slideUp 0.8s ease 0.25s both;
}

.hero-bg__title-main {
  display: block;
  font-size: 0.42em;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: rgba(188, 244, 222, 0.95);
  margin-bottom: 0.45rem;
}

.hero-bg__title-sub {
  display: block;
  font-weight: 700;
  color: #ffffff;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.hero-bg__title--highlight {
  color: var(--color-primary);
  display: block;
}

.hero-bg__subtitle {
  color: rgba(200, 230, 255, 0.80);
  font-size: 1rem;
  font-weight: 500;
  margin-bottom: 1.4rem;
  max-width: 580px;
  line-height: 1.5;
  text-shadow: 0 2px 12px rgba(0, 0, 0, 0.3);
  animation: slideUp 0.8s ease 0.35s both;
}

.hero-bg__subtitle::before {
  content: '';
  display: block;
  width: 36px;
  height: 2px;
  background: linear-gradient(90deg, rgba(0, 230, 118, 0.9) 0%, rgba(92, 216, 255, 0.6) 100%);
  border-radius: 2px;
  margin-bottom: 0.65rem;
}

.hero-bg__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  margin-bottom: 0.65rem;
  animation: slideUp 0.8s ease 0.45s both;
}

.hero-bg__cta-main {
  font-size: 1rem;
}

.hero-bg__cta-secondary {
  font-size: 0.95rem;
}

.hero-bg__microcopy {
  font-size: 0.9rem;
  color: rgba(226, 239, 248, 0.88);
  line-height: 1.4;
  margin: 0;
  animation: slideUp 0.8s ease 0.5s both;
}

.hero-bg__cta-secondary {
  font-size: 0.95rem;
}

/* =========================
   BARRE DE RASSURANCE
   ========================= */

.assurance-bar {
  padding: 1.5rem 0;
  border-top: 1px solid rgba(255, 255, 255, 0.04);
  border-bottom: 1px solid rgba(255, 255, 255, 0.04);
}

.assurance-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 1.5rem;
  align-items: center;
}

.assurance-item {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  font-size: 0.9rem;
  color: var(--color-text-muted);
}

.assurance-item strong {
  font-weight: 600;
  color: var(--color-text);
  display: block;
}

.assurance-item__desc {
  font-size: 0.8rem;
  color: var(--color-text-light);
  display: block;
  margin-top: 0.15rem;
}

.assurance-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 1.5rem;
  height: 1.5rem;
  border-radius: 999px;
  background-color: rgba(0, 230, 118, 0.12);
  color: var(--color-primary);
  font-size: 0.9rem;
  font-weight: bold;
  border: 2px solid #ffffff;
  flex-shrink: 0;
}

/* =========================
   BOUTONS
   ========================= */

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0.95rem 2rem;
  border-radius: 999px;
  border: 1px solid transparent;
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  transition: var(--transition-smooth);
  position: relative;
  overflow: hidden;
}

.btn::before {
  content: "";
  position: absolute;
  inset: 0;
  background-color: rgba(255, 255, 255, 0.1);
  opacity: 0;
  transition: opacity 0.25s ease;
}

.btn--primary {
  background-color: var(--color-primary);
  color: #000000;
  box-shadow: 0 10px 25px rgba(0, 230, 118, 0.3);
}

.btn--primary:hover {
  background-color: var(--color-primary-dark);
  color: #ffffff;
  transform: translateY(-2px);
  box-shadow: 0 14px 35px rgba(0, 230, 118, 0.5);
}

.btn--primary:active {
  transform: translateY(0);
}

.btn--ghost {
  background-color: transparent;
  color: var(--color-text);
  border: 1.5px solid var(--color-primary);
}

.btn--ghost:hover {
  background-color: var(--color-primary);
  color: #000000;
  transform: translateY(-2px);
  box-shadow: 0 10px 25px rgba(0, 230, 118, 0.25);
}

/* =========================
   EXPERTISE INTRO
   ========================= */

.expertise-intro__text {
  max-width: 720px;
  color: var(--color-text-muted);
  font-size: 1rem;
}

/* =========================
   BLOCS (features, services, split, etc.)
   ========================= */

.features {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 2rem;
}

.feature__title {
  font-size: 1.1rem;
  margin-bottom: 0.25rem;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.feature__icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 1.5rem;
  height: 1.5rem;
  border-radius: 999px;
  background-color: rgba(0, 230, 118, 0.1);
  color: var(--color-primary);
  font-size: 0.9rem;
}

.feature__text {
  font-size: 0.95rem;
  color: var(--color-text-muted);
  line-height: 1.6;
}

.services {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 2rem;
}

.service-card {
  padding: 2rem;
  border-radius: 1rem;
  background-color: var(--color-surface);
  border: 1px solid var(--color-border);
  box-shadow: 0 14px 30px var(--color-shadow-soft);
  transition: var(--transition-smooth);
}

.service-card:hover {
  transform: translateY(-8px);
  border-color: rgba(0, 230, 118, 0.5);
  box-shadow: 0 20px 45px rgba(0, 230, 118, 0.15), 0 0 20px rgba(0, 230, 118, 0.1);
}

.service-card__title {
  font-size: 1.1rem;
  margin-bottom: 0.5rem;
}

.service-card__text {
  font-size: 0.95rem;
  color: var(--color-text-muted);
  margin-bottom: 0.75rem;
}

.service-card__link {
  font-size: 0.9rem;
}

/* Split layout (problème / solution) */

.split {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 2rem;
}

.split__title {
  font-size: 1.1rem;
  margin-bottom: 0.5rem;
}

.split__list {
  list-style: none;
}

.split__list li::before {
  content: "→";
  color: var(--color-primary);
  margin-right: 0.5rem;
}

/* Audiences (clients ciblés) */

.audiences {
  list-style: none;
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
}

.audiences--grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 1rem;
}

.audiences__item {
  border-radius: 0.75rem;
  border: 1px solid var(--color-border-soft);
  padding: 0.9rem 1rem;
  font-size: 0.9rem;
  background-color: var(--color-surface-alt);
  display: flex;
  align-items: center;
  gap: 0.5rem;
  transition: var(--transition-smooth);
}

.audiences__item::before {
  content: "";
  width: 0.6rem;
  height: 0.6rem;
  border-radius: 999px;
  background-color: var(--color-primary);
  box-shadow: 0 0 12px rgba(0, 230, 118, 0.6);
}

.audiences__item:hover {
  border-color: var(--color-primary);
  background-color: var(--color-card-hover);
  transform: translateY(-1px);
  box-shadow: 0 10px 24px var(--color-shadow-soft);
}

/* Étapes (processus) */

.steps {
  list-style: none;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 1.5rem;
}

.steps__title {
  font-size: 1.05rem;
  margin-bottom: 0.3rem;
}

/* Expertise block */

.expertise-block {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.expertise-card {
  margin-top: 1rem;
  max-width: 800px;
  padding: 2rem 2.5rem;
  border-radius: 1rem;
  background: radial-gradient(circle at top left, rgba(0, 230, 118, 0.1), var(--color-surface-alt));
  border: 1px solid var(--color-border-strong);
  box-shadow: 0 18px 40px var(--color-shadow-strong);
}

.expertise-card__text {
  color: var(--color-text-muted);
  font-size: 0.98rem;
  margin-bottom: 1.5rem;
}

.expertise-tags {
  list-style: none;
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  margin-bottom: 1.5rem;
}

.expertise-tags__item {
  border-radius: 999px;
  border: 1px solid rgba(0, 230, 118, 0.5);
  padding: 0.4rem 0.9rem;
  font-size: 0.9rem;
  background-color: var(--color-surface-alt);
}

.expertise-card__actions {
  display: flex;
  justify-content: flex-start;
}

/* Projets */

.projects {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 1.5rem;
}

.project-card {
  padding: 2rem;
  border-radius: 1rem;
  background-color: var(--color-surface-alt);
  border: 1px solid var(--color-border-strong);
  box-shadow: 0 10px 26px var(--color-shadow-soft);
  position: relative;
  overflow: hidden;
  transition: var(--transition-smooth);
}

.project-card::before {
  content: "";
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at top left, rgba(0, 230, 118, 0.18), transparent 55%);
  opacity: 0;
  transition: opacity 0.15s ease;
  pointer-events: none;
}

.project-card__title {
  font-size: 1.1rem;
  margin-bottom: 0.5rem;
}

.project-card__text {
  font-size: 0.95rem;
  color: var(--color-text-muted);
  margin-bottom: 0.6rem;
}

.project-card__meta {
  font-size: 0.85rem;
  color: var(--color-text-muted);
  opacity: 0.9;
}

.project-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 20px 45px rgba(0, 230, 118, 0.15), 0 0 20px rgba(0, 230, 118, 0.1);
  border-color: rgba(0, 230, 118, 0.7);
  background-color: var(--color-card-hover);
}

.project-card:hover::before {
  opacity: 1;
}

/* Ressources */

.resources {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 1.5rem;
}

.resource-card {
  padding: 2rem;
  border-radius: 1rem;
  background-color: var(--color-surface);
  border: 1px solid var(--color-border);
  box-shadow: 0 14px 30px var(--color-shadow-soft);
  transition: var(--transition-smooth);
}

.resource-card:hover {
  transform: translateY(-6px);
  border-color: rgba(0, 230, 118, 0.5);
  box-shadow: 0 18px 40px rgba(0, 230, 118, 0.1);
}

.resource-card__title {
  font-size: 1.05rem;
  margin-bottom: 0.5rem;
}

.resource-card__text {
  font-size: 0.95rem;
  color: var(--color-text-muted);
  margin-bottom: 0.75rem;
}

/* Contact */

.contact-grid {
  display: grid;
  grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.85fr);
  gap: 2rem;
  align-items: start;
}

.contact-form,
.contact-panel {
  padding: 2rem;
  border-radius: 1rem;
  background-color: var(--color-surface-alt);
  border: 1px solid var(--color-border-strong);
  box-shadow: 0 12px 30px var(--color-shadow-soft);
}

.contact-form {
  display: grid;
  gap: 1rem;
}

.contact-form__row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 1rem;
}

.contact-form__field {
  display: grid;
  gap: 0.45rem;
}

.contact-form__label {
  font-size: 0.92rem;
  color: var(--color-text-muted);
}

.contact-form__input,
.contact-form__textarea,
.contact-form__select {
  width: 100%;
  border: 1px solid var(--color-border-strong);
  background-color: var(--color-surface-soft);
  color: var(--color-text);
  border-radius: 0.75rem;
  padding: 0.95rem 1rem;
  font: inherit;
  transition: var(--transition-smooth);
}

.contact-form__textarea {
  min-height: 160px;
  resize: vertical;
}

.contact-form__input:focus,
.contact-form__textarea:focus,
.contact-form__select:focus {
  outline: none;
  border-color: rgba(0, 230, 118, 0.75);
  box-shadow: 0 0 0 4px rgba(0, 230, 118, 0.08);
}

.contact-form__help {
  font-size: 0.85rem;
  color: var(--color-text-muted);
  opacity: 0.9;
}

.contact-form__consent {
  display: flex;
  align-items: flex-start;
  gap: 0.65rem;
  padding: 0.8rem 0.9rem;
  border-radius: 0.75rem;
  border: 1px solid var(--color-border-strong);
  background-color: var(--color-surface-soft);
}

.contact-form__consent input {
  margin-top: 0.2rem;
  accent-color: var(--color-primary);
}

.contact-form__consent label {
  font-size: 0.86rem;
  color: var(--color-text-muted);
  line-height: 1.55;
}

.contact-panel {
  display: grid;
  gap: 1.25rem;
}

.contact-panel__title {
  font-size: 1.15rem;
}

.contact-panel__text {
  color: var(--color-text-muted);
  font-size: 0.95rem;
}

.contact-panel__list {
  list-style: none;
  display: grid;
  gap: 0.85rem;
}

.contact-panel__list li {
  padding: 0.95rem 1rem;
  border-radius: 0.8rem;
  border: 1px solid var(--color-border-strong);
  background-color: var(--color-surface-soft);
  color: var(--color-text-muted);
}

.contact-panel__list strong {
  display: block;
  margin-bottom: 0.25rem;
  color: var(--color-text);
}

.contact-panel__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
}

/* FAQ */

.faq__list {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1rem;
}

.faq__item {
  padding: 1.5rem 1.75rem;
  border-radius: 1rem;
  background-color: var(--color-surface);
  border: 1px solid var(--color-border);
  box-shadow: 0 14px 30px var(--color-shadow-soft);
  transition: var(--transition-smooth);
}

.faq__item:hover {
  border-color: rgba(0, 230, 118, 0.3);
  box-shadow: 0 14px 35px rgba(0, 230, 118, 0.08);
}

.faq__question {
  font-size: 1.05rem;
  text-align: left;
}

.faq__trigger {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  background: transparent;
  border: 0;
  color: var(--color-text);
  cursor: pointer;
  font: inherit;
  text-align: left;
}

.faq__arrow {
  color: var(--color-primary);
  font-size: 1rem;
  transition: transform 0.2s ease;
}

.faq__item.is-open .faq__arrow {
  transform: rotate(180deg);
}

.faq__answer {
  margin-top: 0.75rem;
  font-size: 0.95rem;
  color: var(--color-text-muted);
}

/* =========================
   FOOTER GLOBAL
   ========================= */

.site-footer {
  border-top: 1px solid var(--color-border);
  padding: 2rem 0 1rem;
  background-color: var(--color-footer-bg);
}

.footer__inner {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 1.5rem;
  margin-bottom: 1.5rem;
}

.footer__logo {
  font-weight: 700;
  letter-spacing: 0.07em;
}

.footer__text {
  font-size: 0.9rem;
  color: var(--color-text-muted);
}

.footer__title {
  font-size: 0.95rem;
  margin-bottom: 0.5rem;
}

.footer__list {
  list-style: none;
  font-size: 0.9rem;
}

.footer__list li + li {
  margin-top: 0.25rem;
}

.footer__bottom {
  border-top: 1px solid #222222;
  padding-top: 0.75rem;
  font-size: 0.8rem;
  color: var(--color-text-muted);
}

.footer__legal {
  margin-top: 0.55rem;
  font-size: 0.8rem;
  color: var(--color-text-muted);
  line-height: 1.55;
}

.footer__legal a {
  color: var(--color-primary);
}

.footer__legal-btn {
  border: 0;
  border-bottom: 1px solid var(--color-primary);
  background: transparent;
  color: var(--color-primary);
  font: inherit;
  font-size: 0.8rem;
  cursor: pointer;
  padding: 0;
}

.footer__legal-btn:hover {
  color: var(--color-primary-dark);
  border-bottom-color: var(--color-primary-dark);
}

.cookie-banner {
  position: fixed;
  right: 1rem;
  bottom: 1rem;
  z-index: 999;
  width: min(420px, calc(100vw - 2rem));
  border: 1px solid var(--color-border-strong);
  border-radius: 1rem;
  background: var(--color-surface-alt);
  box-shadow: 0 18px 45px var(--color-shadow-strong);
}

.cookie-banner__content {
  display: grid;
  gap: 0.9rem;
  padding: 1rem;
}

.cookie-banner__title {
  font-size: 1.05rem;
}

.cookie-banner__text,
.cookie-banner__links {
  font-size: 0.86rem;
  color: var(--color-text-muted);
}

.cookie-banner__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.55rem;
}

.cookie-banner__actions .btn {
  padding: 0.6rem 1rem;
  font-size: 0.85rem;
}

.cookie-banner__settings {
  margin-top: 0.2rem;
  padding-top: 0.85rem;
  border-top: 1px solid var(--color-border);
  display: grid;
  gap: 0.55rem;
}

.cookie-banner__option {
  font-size: 0.84rem;
  color: var(--color-text-muted);
  display: flex;
  gap: 0.5rem;
  align-items: center;
}

.cookie-banner__option input {
  accent-color: var(--color-primary);
}

.cookie-banner__actions--inline {
  margin-top: 0.3rem;
}

/* =========================
   FOUNDER MESSAGE
   ========================= */

.founder-message {
  background: var(--color-bg-alt-2);
  padding: 3rem 1.5rem;
  margin: 3rem 12rem;
  border-radius: 1rem;
  border: 1px solid rgba(0, 230, 118, 0.2);
  box-shadow: 0 18px 40px rgba(0, 0, 0, 0.35);
}

.founder-message h2 {
  font-size: 1.9rem;
  margin-bottom: 1.2rem;
  color: var(--color-text);
}

.founder-intro {
  font-style: italic;
  color: var(--color-text-muted);
  margin-bottom: 1.2rem;
}

.founder-message p {
  margin-bottom: 1rem;
  line-height: 1.7;
  color: var(--color-text-muted);
}

.founder-list {
  margin: 0 0 1.2rem 1.2rem;
  padding-left: 1rem;
  list-style: disc;
}

.founder-list li {
  color: var(--color-text-muted);
  margin-bottom: 0.4rem;
}

.founder-list li::marker {
  color: var(--color-primary);
}

/* =========================
   PROBLEM SOLUTION SECTION
   ========================= */

.problem-solution {
  background: var(--color-bg-alt-2);
  padding: 3rem 1.5rem;
  margin: 3rem 12rem;
  border-radius: 1rem;
  border: 1px solid rgba(0, 230, 118, 0.2);
  box-shadow: 0 18px 40px rgba(0, 0, 0, 0.35);
}

/* =========================
   RESPONSIVE
   ========================= */

@media (max-width: 768px) {
  .main-nav {
    display: none; /* plus tard : menu burger */
  }

  .header__inner {
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.65rem;
  }

  .language-switcher {
    order: 2;
  }

  .theme-toggle {
    order: 3;
    min-width: auto;
  }

  .top-bar__inner {
    flex-direction: column;
    gap: 0.4rem;
    align-items: stretch;
    padding-right: 0;
  }

  .top-bar__message {
    font-size: 0.8rem;
    text-align: left;
  }

  .top-bar__phone {
    position: static;
    transform: none;
    margin-left: auto;
    font-size: 0.85rem;
  }

  .hero-bg {
    background-position: center;
    min-height: 72vh;
  }

  .hero-bg__inner {
    padding: 3rem 0 2rem;
  }

  .hero-bg__title {
    font-size: 1.05rem;
    margin-bottom: 0.45rem;
  }

  .hero-bg__headline {
    font-size: 1.85rem;
    margin-bottom: 0.8rem;
  }

  .hero-bg__subtitle {
    font-size: 0.93rem;
    margin-bottom: 1.1rem;
  }

  .hero-bg__subtitle::before {
    width: 28px;
    margin-bottom: 0.5rem;
  }

  .hero-bg__actions {
    gap: 0.7rem;
    margin-bottom: 0.5rem;
  }

  .btn {
    padding: 0.85rem 1.5rem;
    font-size: 0.9rem;
  }

  .assurance-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.2rem;
  }

  .assurance-item {
    font-size: 0.85rem;
  }

  .section__title {
    font-size: 1.8rem;
  }

  .section {
    padding: 4rem 0;
  }

  .contact-grid {
    grid-template-columns: 1fr;
  }

  .contact-form__row {
    grid-template-columns: 1fr;
  }

  .cookie-banner {
    left: 0.75rem;
    right: 0.75rem;
    bottom: 0.75rem;
    width: auto;
  }
}

@media (max-width: 480px) {
  .hero-bg__title {
    font-size: 1.9rem;
    line-height: 1.2;
  }

  .btn {
    padding: 0.75rem 1.2rem;
    font-size: 0.85rem;
    width: 100%;
  }

  .hero-bg__actions {
    flex-direction: column;
  }
}

@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
}
