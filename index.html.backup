  <!-- Schema.org : LocalBusiness + FAQPage -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "LocalBusiness",
        "@id": "https://nextiweb.ca/#organization",
        "name": "NEXTIWEB",
        "url": "https://nextiweb.ca/",
        "logo": {
          "@type": "ImageObject",
          "url": "https://nextiweb.ca/assets/img/logo/logo-nextiweb-agence-web-montreal.png"
        },
        "description": "Agence web à Montréal spécialisée en création de sites web, SEO et marketing digital pour PME et entreprises de services.",
        "email": "contact@nextiweb.ca",
        "telephone": "+15147910591",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Montréal",
          "addressRegion": "QC",
          "addressCountry": "CA"
        },
        "areaServed": [
          { "@type": "City", "name": "Montréal" },
          { "@type": "City", "name": "Québec" },
          { "@type": "Country", "name": "Canada" }
        ],
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Services web",
          "itemListElement": [
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Création de sites web" } },
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Référencement SEO" } },
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Marketing digital" } }
          ]
        },
        "inLanguage": ["fr", "en"]
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Combien coûte un site web ?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Le budget dépend de la taille du projet, des fonctionnalités et du niveau d'accompagnement. Nous proposons des solutions adaptées aux PME et entreprises en croissance."
            }
          },
          {
            "@type": "Question",
            "name": "Combien de temps prend la création d'un site ?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "En moyenne entre 4 et 8 semaines, selon la complexité et la rapidité des validations."
            }
          },
          {
            "@type": "Question",
            "name": "Mon site sera-t-il compatible mobile ?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Oui, tous les sites que nous créons sont responsive et pensés mobile-first."
            }
          },
          {
            "@type": "Question",
            "name": "Puis-je modifier mon site moi-même ?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Nous pouvons prévoir une interface simple pour modifier les contenus principaux ou vous accompagner sur la durée."
            }
          },
          {
            "@type": "Question",
            "name": "Proposez-vous aussi le référencement local à Montréal ?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Oui, nous optimisons votre site pour le SEO local : structure des pages, contenus géolocalisés et bonnes pratiques techniques pour améliorer votre visibilité sur Montréal et les zones voisines."
            }
          }
        ]
      }
    ]
  }
  </script>
</head>
